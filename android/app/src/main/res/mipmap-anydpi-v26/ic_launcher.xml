<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon (API 26+) — the system composites this background +
  foreground pair and applies its own mask (circle, squircle, etc.),
  so pre-API-26 devices instead fall back to the flat
  mipmap-*dpi/ic_launcher.png files (see MainActivity.kt's sibling
  resources) generated from the same master artwork.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/splashBackground" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
